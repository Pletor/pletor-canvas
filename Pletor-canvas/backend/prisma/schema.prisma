generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Canvas {
  id          String   @id @default(cuid())
  name        String   @default("Nový canvas")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  nodes CanvasNode[]
  edges CanvasEdge[]
}

model CanvasNode {
  id          String   @id @default(cuid())
  canvasId    String
  nodeType    String   // folder | file | component | service | api | agent | integration
  label       String
  description String?
  status      String   @default("active") // active | draft | archived
  positionX   Float
  positionY   Float

  // WorkFlowy metadata — připraveno pro Fázi 2
  workflowyNodeId String?
  prompt          String?
  context         String?
  intent          String?
  constraints     String? // JSON array jako string

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  canvas      Canvas       @relation(fields: [canvasId], references: [id], onDelete: Cascade)
  sourceEdges CanvasEdge[] @relation("SourceNode")
  targetEdges CanvasEdge[] @relation("TargetNode")
  executions  AgentExecution[]

  @@index([canvasId])
}

model CanvasEdge {
  id       String @id @default(cuid())
  canvasId String
  edgeType String // import | apiCall | dataFlow | event
  sourceId String
  targetId String
  label    String?
  animated Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  canvas Canvas     @relation(fields: [canvasId], references: [id], onDelete: Cascade)
  source CanvasNode @relation("SourceNode", fields: [sourceId], references: [id], onDelete: Cascade)
  target CanvasNode @relation("TargetNode", fields: [targetId], references: [id], onDelete: Cascade)

  @@index([canvasId])
  @@index([sourceId])
  @@index([targetId])
}

model AgentExecution {
  id          String   @id @default(cuid())
  canvasNodeId String
  status      String   @default("pending") // pending | running | completed | failed
  prompt      String   // Sestavený prompt pro Claude
  context     String   // Sestavený kontext (JSON)
  output      String?  // Výstup od Claude
  error       String?  // Chybová zpráva při selhání
  model       String   @default("claude-sonnet-4-20250514")
  tokensIn    Int?
  tokensOut   Int?
  durationMs  Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  canvasNode CanvasNode @relation(fields: [canvasNodeId], references: [id], onDelete: Cascade)

  @@index([canvasNodeId])
  @@index([status])
}
