{
  "name": "pletor",
  "displayName": "Pletor",
  "description": "AI orchestration canvas for VS Code — plan, structure, and build projects with LLM agents",
  "version": "0.1.0",
  "publisher": "pletor",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Other", "Machine Learning"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pletor.openCanvas",
        "title": "Pletor: Open Canvas"
      },
      {
        "command": "pletor.openPlan",
        "title": "Pletor: Open Plan"
      },
      {
        "command": "pletor.initWorkspace",
        "title": "Pletor: Initialize Workspace"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pletor",
          "title": "Pletor",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "pletor": [
        {
          "id": "pletor.projectTree",
          "name": "Project"
        },
        {
          "id": "pletor.agentStatus",
          "name": "Agents"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "pletor.openCanvas",
          "when": "view == pletor.projectTree",
          "group": "navigation"
        },
        {
          "command": "pletor.openPlan",
          "when": "view == pletor.projectTree",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Pletor",
      "properties": {
        "pletor.anthropicApiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API key for orchestrator and subagents"
        },
        "pletor.defaultModel": {
          "type": "string",
          "default": "claude-opus-4-6",
          "description": "Default Claude model for orchestrator"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run build:extension && npm run build:webview",
    "build:extension": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "build:webview": "cd webview-ui && npm run build",
    "watch": "npm run watch:extension & npm run watch:webview",
    "watch:extension": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "watch:webview": "cd webview-ui && npm run dev",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.4.0"
  }
}
